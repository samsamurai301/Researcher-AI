# Server
PORT=8000
BASE_URL=http://localhost:8000
RESEARCHER_DATA_DIR=.researcher-ai
RESEARCHER_MAX_CONCURRENCY=1

# Safe default. Use native only inside a dedicated container, or docker for one container per job.
RESEARCHER_RUNNER=mock
AI_SCIENTIST_ROOT=vendor/ai-scientist-v2
PYTHON_BIN=python3

# Per-job container runner
RESEARCHER_DOCKER_IMAGE=researcher-ai-scientist:0.1.0
RESEARCHER_DOCKER_PYTHON_BIN=python3
RESEARCHER_DOCKER_GPUS=all
RESEARCHER_DOCKER_CPUS=8
RESEARCHER_DOCKER_MEMORY=32g
RESEARCHER_DOCKER_PIDS=512
RESEARCHER_DOCKER_NETWORK=bridge

# Authentication: none (local only), static, or oidc
AUTH_MODE=none
# RESEARCHER_API_TOKEN=replace-with-a-long-random-token
# OIDC_ISSUER=https://identity.example.com/
# OIDC_AUDIENCE=https://researcher.example.com
# OIDC_JWKS_URI=https://identity.example.com/.well-known/jwks.json
# Token shown by the OpenAI submission portal when domain verification is required.
# OPENAI_APPS_CHALLENGE=

# AI Scientist providers. Never commit real values.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# S2_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION_NAME=

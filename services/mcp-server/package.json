{
  "name": "@researcher-ai/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "dev": "tsx watch src/http.ts",
    "start": "node dist/http.mjs",
    "start:stdio": "node dist/stdio.mjs",
    "pretest": "npm run build --workspace @researcher-ai/widget",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "cors": "2.8.5",
    "express": "5.2.1",
    "jose": "6.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.5",
    "@types/node": "24.10.1",
    "@types/supertest": "6.0.3",
    "esbuild": "0.28.1",
    "supertest": "7.1.4",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
